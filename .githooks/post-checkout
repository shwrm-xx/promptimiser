#!/bin/bash
# Lève la quarantaine macOS sur les .command du dépôt après chaque pull/merge,
# pour éviter le popup Gatekeeper (« Apple n'a pas pu confirmer... ») au double-clic.
# Fail-open : ne doit jamais faire échouer un git pull/merge.
set -u
REPO="$(git rev-parse --show-toplevel 2>/dev/null)" || exit 0
command -v xattr >/dev/null 2>&1 || exit 0
find "$REPO" -name "*.command" -exec xattr -d com.apple.quarantine {} \; 2>/dev/null
exit 0
