#!/bin/bash
# pmz-codex — lance Codex en garantissant un AGENTS.md projet (socle Promptimizer) au préalable.
# Installation : copier dans un dossier du PATH (ex. ~/bin/pmz-codex), chmod +x.
set -u

HERE="$(pwd)"
TPL="$HOME/.claude/promptimizer/templates/AGENTS.md"
BOOT="$HOME/.claude/promptimizer/scripts/bootstrap-project.js"

if [ ! -f "$HERE/AGENTS.md" ]; then
  # Repo git : bootstrap prudent (jamais d'écrasement). Sinon : copie directe du template.
  if command -v node >/dev/null 2>&1 && [ -f "$BOOT" ]; then
    node "$BOOT" >/dev/null 2>&1 || true
  fi
  if [ ! -f "$HERE/AGENTS.md" ] && [ -f "$TPL" ]; then
    cp "$TPL" "$HERE/AGENTS.md"
    echo "pmz-codex : AGENTS.md créé depuis le template Promptimizer."
  fi
fi

if ! command -v codex >/dev/null 2>&1; then
  echo "pmz-codex : binaire 'codex' introuvable dans le PATH." >&2
  exit 127
fi
exec codex "$@"
