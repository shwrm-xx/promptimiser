{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear|compact",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/bin/pmz-hook\" \"${CLAUDE_PLUGIN_ROOT}/hooks/session-start.js\"", "timeout": 10 }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/bin/pmz-hook\" \"${CLAUDE_PLUGIN_ROOT}/hooks/user-prompt-submit.js\"", "timeout": 5 }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/bin/pmz-hook\" \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-tool-use.js\"", "timeout": 5 }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Edit|Write|TodoWrite",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/bin/pmz-hook\" \"${CLAUDE_PLUGIN_ROOT}/hooks/post-tool-use.js\"", "timeout": 5 }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/bin/pmz-hook\" \"${CLAUDE_PLUGIN_ROOT}/hooks/stop.js\"", "timeout": 5 }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "manual|auto",
        "hooks": [
          { "type": "command", "command": "sh \"${CLAUDE_PLUGIN_ROOT}/bin/pmz-hook\" \"${CLAUDE_PLUGIN_ROOT}/hooks/pre-compact.js\"", "timeout": 5 }
        ]
      }
    ]
  }
}
